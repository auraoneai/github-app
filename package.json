{
  "name": "@auraone/github-app",
  "version": "0.2.0",
  "description": "Self-hosted GitHub App that reports AuraOne PR evaluations in one lifecycle-aware Check Run and one idempotent bot-owned PR summary.",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix"
  },
  "keywords": [
    "ai-evaluation",
    "ai-evals",
    "agent-evaluation",
    "auraone",
    "branch-protection",
    "check-run",
    "code-review",
    "developer-tools",
    "github",
    "github-app",
    "github-checks",
    "llm-evaluation",
    "merge-gate",
    "pull-request",
    "pull-request-checks",
    "quality-gate",
    "self-hosted",
    "webhook"
  ],
  "author": "AuraOne",
  "license": "MIT",
  "dependencies": {
    "@octokit/app": "^14.0.2",
    "@octokit/webhooks": "^12.0.4",
    "@auraone/sdk": "^0.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/auraoneai/github-app.git"
  },
  "bugs": {
    "url": "https://github.com/auraoneai/github-app/issues"
  },
  "homepage": "https://github.com/auraoneai/github-app#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
